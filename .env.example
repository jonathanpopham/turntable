# Railway auth. RAILWAY_TOKEN (project-scoped, preferred at runtime: blast
# radius is one project) or RAILWAY_API_TOKEN (account-wide bearer, needed by
# scripts/smoke.sh for the independent cleanup check).
RAILWAY_TOKEN=
RAILWAY_API_TOKEN=

# The dedicated project and environment the managed container lives in.
# Blast radius is bounded to this project by construction.
TARGET_PROJECT_ID=
TARGET_ENVIRONMENT_ID=

# Login passphrase for the deployed UI, minimum 16 characters. The app is
# public and its button spends money.
APP_PASSWORD=

# Where durable desired intent lives. On Railway: mount a volume at /data and
# set STATE_DIR=/data, or the app refuses to boot (restart-survival would be
# silently false on ephemeral disk). Locally ./state is the default.
STATE_DIR=

PORT=3000
